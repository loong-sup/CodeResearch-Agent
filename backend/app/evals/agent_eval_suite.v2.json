    {
      "id": "code_mcp_server_impl",
      "question": "请说明这个项目里的 MCP Server 是怎么实现的，包括 Server 创建、tools/list 和 tools/call 的处理。",
      "repository_ids": [],
      "web_search": false,
      "expected_file_paths": [
        "src/mcp_server/protocol_handler.py",
        "src/mcp_server/server.py",
        "src/mcp_server/tools/query_knowledge_hub.py"
      ],
      "must_include": [
        "create_mcp_server",
        "ProtocolHandler",
        "tools/list",
        "tools/call"
      ],
      "must_not_include": [
        "请提供 src/mcp_server",
        "无法说明 MCP Server"
      ],
      "require_citations": true,
      "forbid_failure_phrases": true,
      "tags": [
        "code_first",
        "mcp",
        "implementation"
      ]
